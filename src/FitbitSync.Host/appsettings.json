{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Storage": {
    "DatabasePath": "fitbitsync.db"
  },
  "Fitbit": {
    "RedirectUri": "http://127.0.0.1:7654/callback",
    "Scopes": [
      "activity",
      "heartrate",
      "sleep",
      "oxygen_saturation",
      "respiratory_rate",
      "temperature",
      "cardio_fitness"
    ]
  }
}
